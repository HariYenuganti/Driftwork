generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model JobItem {
  id             String   @id
  title          String
  company        String
  badgeLetters   String
  daysAgo        Int
  relevanceScore Int
  date           String
  seniority      String
  tags           String
  remote         Boolean

  description    String
  qualifications String
  reviews        String
  duration       String
  salary         String
  location       String
  coverImgURL    String
  companyURL     String

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
