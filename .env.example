# Postgres connection string (Prisma Postgres via Vercel Marketplace).
#
# In production: Vercel's Prisma Postgres integration injects `DATABASE_URL`
# automatically — provisioned via Storage → Create Database → Prisma Postgres
# (or `vercel integration add prisma-postgres`).
#
# Locally: run `vercel env pull .env` to copy the prod value into .env, or
# paste a Prisma Postgres / Neon connection string here.

DATABASE_URL="postgres://user:pass@host:5432/dbname?sslmode=require"
