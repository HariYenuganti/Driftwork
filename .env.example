# Postgres connection strings.
#
# In production: Vercel's Postgres integration injects these automatically
# when you provision a database from Storage → Create Database → Postgres.
#
# Locally: create a Neon dev branch at https://neon.tech (or use `vercel env pull`
# to copy the prod values into .env.local). Neon free tier supports branching —
# create a separate branch for local dev to keep prod data untouched.

# Pooled (pgbouncer) — used at runtime by Prisma queries.
POSTGRES_PRISMA_URL="postgresql://user:pass@host/dbname?pgbouncer=true&connect_timeout=15"

# Direct (bypasses pgbouncer) — used by `prisma db push`, migrations, seed.
POSTGRES_URL_NON_POOLING="postgresql://user:pass@host/dbname"
